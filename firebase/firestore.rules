rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function nigeriaVolunteer() {
      return get(/databases/$(database)/documents/nigeria_volunteers/$(request.auth.uid)).data;
    }

    function nigeriaCanAccessUnit(unitId) {
      let v = nigeriaVolunteer();
      return (v.unitIds != null && unitId in v.unitIds) || v.unitId == unitId;
    }

    // Populated by Cloud Functions only. Clients never read this directly.
    match /volunteer_onboarding/{docId} {
      allow read, write: if false;
    }

    // Volunteer profile (document ID = Firebase Auth uid).
    match /volunteers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Public roster (name, tent, shifts, photo only — no email). Writes: owner only.
    match /volunteer_directory/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Shift channels + wall; anyone can read; only signed-in volunteers can post (spam control).
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.fromUid == request.auth.uid;
      allow update: if false;
    }

    match /community_waves/{waveId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.fromUid == request.auth.uid;
      allow update: if false;
    }

    // Ops settings + intelligence run logs — Cloud Functions only.
    match /settings/{docId} {
      allow read, write: if false;
    }

    match /digest_intelligence_runs/{runId} {
      allow read, write: if false;
    }

    // Nigeria regional volunteers (+234 phone sign-in).
    match /nigeria_volunteers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /nigeria_attendance/{attendanceId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid
            || get(/databases/$(database)/documents/nigeria_volunteers/$(request.auth.uid)).data.unitId == resource.data.unitId
               && get(/databases/$(database)/documents/nigeria_volunteers/$(request.auth.uid)).data.role == 'leader');
      allow create: if false;
      allow update, delete: if false;
    }

    match /nigeria_unit_reports/{reportId} {
      allow read: if request.auth != null && nigeriaCanAccessUnit(resource.data.unitId);
      allow write: if false;
    }

    // Collaborative monthly report draft — share, contribute, approve via Cloud Functions.
    match /nigeria_unit_report_drafts/{draftId} {
      allow read: if request.auth != null && nigeriaCanAccessUnit(resource.data.unitId);
      allow write: if false;
    }

    match /nigeria_meeting_reminder_sent/{sentId} {
      allow read, write: if false;
    }

    // Shared notes for a unit meeting — all members of that unit can read/write.
    match /nigeria_unit_meeting_notes/{noteId} {
      allow read: if request.auth != null && nigeriaCanAccessUnit(resource.data.unitId);
      allow create, update: if request.auth != null
        && request.resource.data.updatedByUid == request.auth.uid
        && nigeriaCanAccessUnit(request.resource.data.unitId);
      allow delete: if false;
    }
  }
}
