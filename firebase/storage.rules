rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos: public read (for avatars in UI); only owner can write; images only, max ~3MB.
    match /volunteer_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
